{
  // server(controller)地址,必填。支持裸 IP/裸域名,端口可省略
  // 例:121.40.193.74  example.com  https://sdwan.example.com
  "controller": "http://121.40.193.74:52888",

  // 注册账号/密码(v0.7.0 起必填,在 Web 面板"账号"页创建;
  // 所属网络由账号绑定的公司决定,无需在此选择)
  "username": "",
  "password": "",

  // 设备名称,显示在面板设备列表;留空自动使用主机名
  "name": "",

  // 站点到站点:共享给对端网络的本机 LAN 网段(逗号分隔 CIDR),不共享留空。
  // 填法:Windows 运行 ipconfig,按网卡 IPv4+子网掩码换算,
  // 如 192.168.1.34 / 255.255.255.0 → "192.168.1.0/24"
  "lan": "",

  // 私钥文件(首次运行自动生成;删除即换身份,面板会分配新虚拟 IP)
  "key": "aleiyun_client.key",
  // WireGuard 监听端口
  "listen_port": 51820,
  // 日志文件(屏幕和文件同时输出)
  "log": "aleiyun_client.log",

  // 以下为可选项,一般不填:
  // STUN 服务器地址(空=从 controller 地址推导)
  "stun": "",
  // 只注册不起隧道(调试用,无需管理员权限)
  "no_tun": false,
  // 输出 WireGuard 握手等详细日志
  "debug": false,
  // 已废弃:所属网络由账号绑定决定,此字段被服务端忽略
  "network": ""
}
